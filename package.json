{
  "name": "@rakelabs/dpay-mcp",
  "version": "0.1.6",
  "description": "MCP server for Disputable Payments — lets AI agents create, settle, dispute, and refund Ethereum escrows on-chain",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/programmaman/dpay-mcp.git"
  },
  "homepage": "https://github.com/programmaman/dpay-mcp#readme",
  "bugs": {
    "url": "https://github.com/programmaman/dpay-mcp/issues"
  },
  "mcpName": "io.github.programmaman/dpay-mcp",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dpay-mcp": "./dist/src/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist dist-test coverage",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "tsc && node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "agent": "tsx test/agent/agent-client.ts",
    "demo:two-agent": "npm run build && tsx test/agent/two-agent-demo.ts",
    "demo:openai": "npm run build && tsx test/agent/two-agent-openai.ts",
    "demo:server": "tsx src/demo/demo-server.ts",
    "test:up": "docker compose -f test/docker-compose.yml up -d",
    "test:down": "docker compose -f test/docker-compose.yml down",
    "test:logs": "docker compose -f test/docker-compose.yml logs -f ollama",
    "test:ping": "tsx test/ping.test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && tsx test/ping.test.ts && vitest run test/create-payment.test.ts test/lifecycle.test.ts test/dispute.test.ts",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rakelabs/dpayments-sdk": "^0.1.1",
    "@rakelabs/evidence-publisher": "^0.1.1",
    "ethers": "^6.17.0",
    "express": "^5.2.1",
    "json5": "^2.2.3",
    "pino": "^10.3.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
