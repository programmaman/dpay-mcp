# Required
RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
CHAIN_ID=1

# Wallet (omit for auto-generated — saved to ~/.dpay-mcp/wallet-key)
# PRIVATE_KEY=0x...

# Required — spending limits. Format: address|name:budget:maxTxValue,...
# Built-in aliases: ETH, USDC
# Example: 0.1 ETH session budget + 0.01 ETH per tx, and 500 USDC total + 100 per tx
ALLOWED_TOKENS=ETH:0.1:0.01,0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48:500:100

# Minimum settlement window (optional, default: none)
# MIN_SETTLEMENT_WINDOW_SEC=3600

# Factory address override (optional — omit if the factory is known for your chain)
# FACTORY_ADDRESS=0x...

# Policy webhook (optional — fail-closed: unreachable = denies all writes)
# POLICY_WEBHOOK_URL=https://...
# POLICY_WEBHOOK_TOKEN=...

# Evidence storage (optional — omit for in-process Helia, set for a remote IPFS endpoint like Pinata)
# EVIDENCE_IPFS_ENDPOINT=https://api.pinata.cloud/pinning/pinFileToIPFS
# EVIDENCE_IPFS_AUTH_TYPE=bearer
# EVIDENCE_IPFS_AUTH_TOKEN=pinata-jwt-token
# EVIDENCE_IPFS_HEADERS={"network":"public"}
# EVIDENCE_IPFS_UPLOAD_FIELDS={"network":"public"}
# EVIDENCE_IPFS_FILE_FIELD=file
# EVIDENCE_IPFS_GATEWAYS=https://gateway.pinata.cloud,https://ipfs.io
# EVIDENCE_PROVIDER_URL=https://api.pinata.cloud/pinning/pinFileToIPFS
# EVIDENCE_PROVIDER_AUTH_TYPE=bearer
# EVIDENCE_PROVIDER_AUTH_TOKEN=pinata-jwt-token

